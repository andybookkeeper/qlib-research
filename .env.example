# .env.example
# FastAPI
# Use development for local work, production for deployed environments.
FASTAPI_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration (Phase 2)
# Choose one: SQLite (development) or PostgreSQL (production)
# SQLite: sqlite:///./data/qlib_trading.db
# PostgreSQL: postgresql://qlib_user:qlib_password@localhost:5432/qlib_trading
DATABASE_URL=sqlite:///./data/qlib_trading.db

# Data paths
DATA_PATH=./data
QLIB_DATA_PATH=./data/qlib
MLRUNS_PATH=./mlruns

# Qlib
QLIB_REGION=US
QLIB_PROVIDER=yahoo

# Portfolio
INITIAL_CASH=100000
MAX_POSITION_PCT=0.10
MAX_LEVERAGE=1.0

# Models
ACTIVE_MODEL=LightGBM-v1
MIN_CONFIDENCE=0.60

# Execution
ENABLE_LIVE_TRADING=false
PAPER_TRADING_MODE=true

# Phase 3 feature flags (all OFF by default for safe rollout)
PHASE3_SCOPE_STAGE=kickoff
PHASE3_ENABLE_LIVE_BROKER_ADAPTER=false
PHASE3_ENABLE_BROKER_RECONCILIATION=false
PHASE3_ENABLE_STRATEGY_AUTOMATION=false
PHASE3_ENFORCE_MANUAL_TRADE_CONFIRMATION=true
PHASE3_LIVE_BROKER_PROVIDER=not-configured
PHASE3_MAX_TRADE_NOTIONAL=25000
PHASE3_MAX_POSITION_NOTIONAL=50000
PHASE3_MAX_DAILY_LOSS=5000
PHASE3_RECONCILIATION_WINDOW_DAYS=30
PHASE3_RECONCILIATION_WIN_RATE_DELTA=-0.05
PHASE3_RECONCILIATION_SHARPE_DELTA=-0.15
PHASE3_RECONCILIATION_RETURN_DELTA=-0.10
PHASE3_RECONCILIATION_INTERVAL_SECONDS=900

# JWT Configuration (Phase 2-03)
# REQUIRED for production: set a strong random value
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
