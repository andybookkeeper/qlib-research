# .env.example
# FastAPI
FASTAPI_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data paths
DATA_PATH=./data
QLIB_DATA_PATH=./data/qlib
MLRUNS_PATH=./mlruns

# Qlib
QLIB_REGION=US
QLIB_PROVIDER=yahoo

# Portfolio
INITIAL_CASH=100000
MAX_POSITION_PCT=0.10
MAX_LEVERAGE=1.0

# Models
ACTIVE_MODEL=LightGBM-v1
MIN_CONFIDENCE=0.60

# Execution
ENABLE_LIVE_TRADING=false
PAPER_TRADING_MODE=true
